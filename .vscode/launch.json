{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        },
        {
            "name": "OM",
            "consoleName": "OM",
            "type": "debugpy",
            "request": "launch",
            "python": "${command:python.interpreterPath}",
            "module": "flask",
            "env": {
                "FLASK_APP": "app:create_app()",
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "1",
                "OM_APP_NAME": "order_master",
                "OM_CONFIG_FILE": "config-default.json"
            },
            "args": [
                "run",
                // "--host",
                // "0.0.0.0"
            ],
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "NetMan",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "cwd": "${workspaceFolder}/network_builder",
            "env": {
                "FLASK_APP": "netman_app",
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "1",
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "run",
                "--host",
                "0.0.0.0",
                "--port",
                "5001"
            ],
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "NetBuild",
            "type": "debugpy",
            "request": "launch",
            "module": "build_network",
            "cwd": "${workspaceFolder}/network_builder",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "EC FE",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}/eurocargo_management/frontend"
        },
        {
            "name": "EC BE",
            "consoleName": "EC BE",
            "type": "debugpy",
            "request": "launch",
            "python": "/Users/ralfeus/.virtualenvs/eurocargo/bin/python",
            "module": "uvicorn",
            "args": ["app.main:app", "--reload"],
            "cwd": "${workspaceFolder}/eurocargo_management/backend",
            "env": {
                "DATABASE_URL": "postgresql://ralfeus@localhost/shipment",
                "ECM_API_KEY": "supersecretkey",
            }
        }
    ]
}